# Auth & credentials - never commit
.credentials.json

# Cache & temp files
cache/
stats-cache.json
mcp-needs-auth-cache.json
statsig/

# Session & history - machine specific
sessions/
session-env/
history.jsonl
shell-snapshots/
file-history/

# Debug & telemetry
debug/
telemetry/
usage-data/

# IDE & browser state - machine specific
ide/
chrome/

# Downloads & backups - machine specific
downloads/
backups/

# Projects - exclude session/agent data, keep memory
projects/**/*.jsonl
projects/**/subagents/
projects/**/tool-results/
projects/**/sessions-index.json

# Plugin marketplaces - re-downloaded by Claude Code automatically
plugins/

# Playwright Session Data
claude_session.json
.playwright-cli/
.claude/claude_profile/
